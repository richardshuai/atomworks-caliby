Bootstrap: docker
From: python:3.12-slim

%labels
    Author Institute for Protein Design
    Version 1.0.4
    Description AtomWorks - A research-oriented data toolkit for training biomolecular deep-learning foundation models

%files
    # Only copy pyproject.toml for dependency installation
    ../../pyproject.toml /opt/atomworks/pyproject.toml

%post
    # Update system and install essential packages
    apt-get update && apt-get install -y \
        build-essential \
        git \
        libxrender1 \
        libxrender-dev \
        libx11-6 \
        libx11-dev \
        && rm -rf /var/lib/apt/lists/*
    
    # Upgrade pip
    python -m pip install --upgrade pip

    # Install uv for fast dependency resolution
    pip install uv

    # Install the package with all dependencies from pyproject.toml
    uv pip install --system -r /opt/atomworks/pyproject.toml --all-extras

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec "$@"

%help
    AtomWorks Development Apptainer

    Usage:
        apptainer exec atomworks.sif atomworks --help
        apptainer exec atomworks.sif aw --help
